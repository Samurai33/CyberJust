# Copy to .env.local for development, or set as environment variables in Vercel.
# Never commit the real values.

# Password required to unlock the internal dashboard (see app/actions/auth.ts).
# Choose a strong, unique value — do not reuse this anywhere else.
DASHBOARD_PASSWORD=

# Secret used to sign the dashboard session cookie (HMAC-SHA256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=
